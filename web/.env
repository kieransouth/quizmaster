# Default Vite env for `npm run build`. The Dockerfile.web build can
# override VITE_ROBOTS via the WEB_ROBOTS build arg (set in
# docker-compose.yml from the .env at the repo root).
#
# noindex,nofollow keeps a self-hosted instance out of Google by
# default. The live deploy explicitly sets WEB_ROBOTS=index,follow.
VITE_ROBOTS=noindex,nofollow
