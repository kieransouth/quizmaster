# Copy this file to .env and fill in real values. .env is gitignored.

# --- Postgres ---
POSTGRES_DB=quizmaster
POSTGRES_USER=quizmaster
POSTGRES_PASSWORD=change-me-strong-password

# --- JWT ---
# A long random string. Generate with: openssl rand -base64 64
JWT_SIGNING_KEY=change-me-jwt-signing-key-at-least-32-chars

# --- AI: Ollama (local container, talks to Ollama Cloud) ---
# Get from https://ollama.com (account → API keys)
OLLAMA_CLOUD_API_KEY=
# Default model used when the UI doesn't specify one
OLLAMA_DEFAULT_MODEL=qwen2.5:72b

# --- AI: OpenAI (optional) ---
OPENAI_API_KEY=

# --- AI: Anthropic (optional) ---
ANTHROPIC_API_KEY=
