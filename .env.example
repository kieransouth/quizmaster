# Copy this file to .env and fill in real values. .env is gitignored.

# --- Standalone host port ---
# The web service is published on 127.0.0.1:WEB_PORT. Point your reverse
# proxy (Caddy / nginx / Cloudflare Tunnel) at it. Edit the bind in
# docker-compose.yml if you need it on all interfaces.
WEB_PORT=8080

# --- Traefik (only when using docker-compose.traefik.yml overlay) ---
# Public hostname the Traefik routers match. No scheme, no path.
QUIZMASTER_HOST=quizmaster.example.com
# Resolver registered in your Traefik config via
# `--certificatesresolvers.<name>.acme.*` flags. Common: "letsencrypt".
TRAEFIK_CERTRESOLVER=letsencrypt
# Name of the TLS entrypoint defined in your Traefik static config
# (e.g. `--entrypoints.<name>.address=:443`). Defaults to "websecure"
# if unset, which is Traefik's documented convention.
TRAEFIK_ENTRYPOINT=websecure

# --- Postgres ---
POSTGRES_DB=quizmaster
POSTGRES_USER=quizmaster
POSTGRES_PASSWORD=change-me-strong-password

# --- JWT ---
# A long random string. Generate with: openssl rand -base64 64
JWT_SIGNING_KEY=change-me-jwt-signing-key-at-least-32-chars

# --- AI: Ollama (local container, talks to Ollama Cloud) ---
# Get from https://ollama.com (account → API keys)
OLLAMA_CLOUD_API_KEY=
# Default model used when the UI doesn't specify one
OLLAMA_DEFAULT_MODEL=qwen2.5:72b

# --- AI: OpenAI (optional) ---
OPENAI_API_KEY=

# --- AI: Anthropic (optional) ---
ANTHROPIC_API_KEY=

# --- Auth ---
# Set to false to disable new account registration. Existing accounts can
# still sign in. Defaults to true if unset.
REGISTRATION_ENABLED=true
